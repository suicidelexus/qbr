# ==================== Hybrid.ai DSP API Configuration ====================
# Документация: https://docs.hybrid.ai/rest-api-3-0

# ⭐ ГЛАВНОЕ: API KEY (обязательно)
# Получить: https://hybrid.ai → Settings → API Keys → Generate New Key
DSP_API_KEY=your_hybrid_ai_api_key_here

# API URL (уже настроен на Hybrid.ai, менять не нужно)
# DSP_API_URL=https://api.hybrid.ai/v3

# Client ID (требуется редко)
# DSP_CLIENT_ID=your_client_id

# ==================== Google Slides API (optional) ====================
GOOGLE_CREDENTIALS_PATH=credentials.json

# ==================== Report Settings ====================
DEFAULT_PERIOD_DAYS=30

# ==================== Инструкции ====================
# 1. Скопируйте: cp .env.example .env
# 2. Заполните DSP_API_URL и DSP_API_KEY
# 3. Тест: python -c "from data_layer import DSPClient; DSPClient().test_connection()"
